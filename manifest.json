{
  "manifest_version": 3,
  "name": "VIT Faculty Ratings",
  "version": "1.0",
  "description": "Shows faculty ratings next to professor names on VIT pages",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.vit.ac.in/*",
        "*://*.vit.edu.in/*",
        "*://*.vitap.ac.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["faculties.csv"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VIT Faculty Ratings"
  },
  "icons":{
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  }
}